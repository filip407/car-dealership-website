@model List<CarDealership.Models.Sale>
@{
    ViewData["Title"] = "Statistici Vânzări";
    
    // Calcule globale
    var totalRevenue = Model.Sum(s => s.SalePrice);
    var totalCarsSold = Model.Count;

    // Calcule grupate pe agenți
    var agentStats = Model
        .GroupBy(s => s.Agent?.FullName ?? "Agent Necunoscut")
        .Select(g => new {
            AgentName = g.Key,
            CarsSold = g.Count(),
            Revenue = g.Sum(s => s.SalePrice)
        })
        .OrderByDescending(x => x.Revenue)
        .ToList();
}

<h2 class="mb-4">Statistici și Performanță</h2>

<div class="row mb-5">
    <div class="col-md-6">
        <div class="card bg-primary text-white shadow-sm h-100">
            <div class="card-body text-center">
                <h5 class="card-title">Total Încasări Firmă</h5>
                <h2 class="display-5 fw-bold">@totalRevenue.ToString("C")</h2>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card bg-success text-white shadow-sm h-100">
            <div class="card-body text-center">
                <h5 class="card-title">Total Mașini Vândute</h5>
                <h2 class="display-5 fw-bold">@totalCarsSold unități</h2>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm mb-5">
    <div class="card-header bg-white">
        <h4 class="mb-0">Performanță pe Angajat</h4>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="bg-light">
                <tr>
                    <th>Nume Agent</th>
                    <th class="text-center">Mașini Vândute</th>
                    <th class="text-end">Total Generat</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var stat in agentStats)
                {
                    <tr>
                        <td class="fw-bold">@stat.AgentName</td>
                        <td class="text-center">@stat.CarsSold</td>
                        <td class="text-end text-success fw-bold">@stat.Revenue.ToString("C")</td>
                    </tr>
                }
                @if (!agentStats.Any())
                {
                    <tr>
                        <td colspan="3" class="text-center py-4 text-muted">Nu există vânzări înregistrate încă.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<h4 class="mb-3">Istoric Tranzacții Recente</h4>
<div class="list-group shadow-sm">
    @foreach (var sale in Model.Take(10))
    {
        <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
            <div>
                <h6 class="mb-1">@sale.Car?.Brand?.Name @sale.Car?.ModelName</h6>
                <small class="text-muted">Vândut de: @sale.Agent?.FullName pe @sale.SaleDate.ToString("dd.MM.yyyy")</small>
            </div>
            <span class="badge bg-success rounded-pill fs-6">@sale.SalePrice.ToString("C")</span>
        </div>
    }
</div>