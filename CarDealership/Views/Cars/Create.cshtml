@model CarDealership.ViewModels.CreateCarViewModel
@{
    ViewData["Title"] = "Adaugă Mașină Nouă";
}

<h2 class="mb-4">Adaugă Mașină Nouă</h2>

<div class="row">
    <div class="col-md-8">
        <form asp-action="Create" enctype="multipart/form-data" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <label asp-for="BrandId" class="form-label fw-bold"></label>
                    <select asp-for="BrandId" class="form-select" asp-items="Model.Brands">
                        <option value="">-- Selectează Marca --</option>
                    </select>
                    <span asp-validation-for="BrandId" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="ModelName" class="form-label fw-bold"></label>
                    <input asp-for="ModelName" class="form-control" placeholder="Ex: A4, Q5, RS6..." />
                    <span asp-validation-for="ModelName" class="text-danger"></span>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <label asp-for="Year" class="form-label fw-bold"></label>
                    <input asp-for="Year" class="form-control" />
                    <span asp-validation-for="Year" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Price" class="form-label fw-bold"></label>
                    <input asp-for="Price" class="form-control" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group mb-4">
                <label class="form-label fw-bold">Dotări Opționale</label>
                <div class="row border rounded p-3 bg-light m-0">
                    @foreach (var feature in Model.AllFeatures)
                    {
                        <div class="col-md-4 mb-2">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="SelectedFeatureIds" value="@feature.Id" id="feature_@feature.Id" />
                                <label class="form-check-label" for="feature_@feature.Id">@feature.Name</label>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="form-group mb-4">
                <label asp-for="ImageFile" class="form-label fw-bold"></label>
                <input asp-for="ImageFile" class="form-control" accept="image/*" />
            </div>

            <button type="submit" class="btn btn-primary">Salvează Mașina</button>
            <a asp-action="Index" class="btn btn-outline-secondary ms-2">Înapoi la stoc</a>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}