@model List<CarDealership.ViewModels.CarViewModel>
@{
    ViewData["Title"] = "Mașini";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Stoc Auto</h2>
    @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary">Adaugă Mașină Nouă</a>
    }
</div>

<div class="row">
    @foreach (var car in Model.Where(c => !c.IsSold))
    {
        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm">
                @if (!string.IsNullOrEmpty(car.ImagePath))
                {
                    <img src="@car.ImagePath" class="card-img-top" alt="@car.ModelName" style="height: 200px; object-fit: cover;" />
                }
                else
                {
                    <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                        <span class="text-muted">Fără imagine</span>
                    </div>
                }
                <div class="card-body">
                    <h5 class="card-title">@car.BrandName @car.ModelName</h5>
                    <p class="card-text text-success fw-bold fs-5">@car.Price.ToString("C")</p>
                    <p class="card-text mb-1"><small class="text-muted">An fabricație: @car.Year</small></p>
                </div>
                <div class="card-footer bg-white border-top-0 d-flex justify-content-between align-items-center pb-3">
                    <a asp-action="Details" asp-route-id="@car.Id" class="btn btn-sm btn-outline-primary">Detalii</a>
                    @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
                    {
                        <div>
                            <a asp-action="Sell" asp-route-id="@car.Id" class="btn btn-sm btn-success text-white">Vinde</a>
                            <a asp-action="Edit" asp-route-id="@car.Id" class="btn btn-sm btn-outline-secondary">Editează</a>
                            <form asp-action="Delete" asp-route-id="@car.Id" method="post" class="d-inline" onsubmit="return confirm('Sigur vrei să ștergi această mașină din stoc?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Șterge</button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="col-12 text-center text-muted py-5">
            <h4>Nu există mașini înregistrate în stoc în acest moment.</h4>
        </div>
    }
</div>
