@model CarDealership.ViewModels.CarViewModel
@{
    ViewData["Title"] = "Detalii Mașină";
    bool isInWishlist = ViewBag.IsInWishlist == true;
    string backUrl = ViewBag.ReturnUrl as string ?? Url.Action("Index", "Cars")!;
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger mb-3">@TempData["Error"]</div>
}

<div class="card shadow-sm mt-2">
    <div class="row g-0">
        <div class="col-md-6">
            @if (!string.IsNullOrEmpty(Model.ImagePath))
            {
                <img src="@Model.ImagePath" class="img-fluid h-100 w-100" style="object-fit: cover; min-height: 420px;" alt="@Model.ModelName" />
            }
            else
            {
                <div class="bg-light d-flex align-items-center justify-content-center h-100" style="min-height: 420px;">
                    <span class="text-muted fs-5">Fără imagine</span>
                </div>
            }
        </div>
        <div class="col-md-6">
            <div class="card-body p-5">
                <p class="text-muted mb-1" style="letter-spacing: 0.1em; text-transform: uppercase; font-size: 0.8rem;">@Model.BrandName</p>
                <h2 class="card-title fw-bold mb-1">@Model.ModelName</h2>
                <h3 class="mb-4 mt-2" style="color: #1a1a1a;">@Model.Price.ToString("C")</h3>

                <ul class="list-group list-group-flush mb-4">
                    <li class="list-group-item px-0"><strong>An fabricație:</strong> @Model.Year</li>
                    <li class="list-group-item px-0"><strong>Data adăugării:</strong> @Model.AddedAt.ToString("dd.MM.yyyy")</li>
                    @if (Model.FeatureNames.Any())
                    {
                        <li class="list-group-item px-0">
                            <strong>Dotări:</strong>
                            <div class="mt-1">
                                @foreach (var name in Model.FeatureNames)
                                {
                                    <span class="badge bg-secondary me-1 mb-1">@name</span>
                                }
                            </div>
                        </li>
                    }
                </ul>

                <div class="d-flex flex-wrap gap-2">
                    <a href="@backUrl" class="btn btn-outline-secondary">Înapoi</a>

                    @if (User.IsInRole("Customer"))
                    {
                        if (isInWishlist)
                        {
                            <form asp-controller="Wishlist" asp-action="Remove" method="post">
                                <input type="hidden" name="carId" value="@Model.Id" />
                                <button type="submit" class="btn btn-outline-secondary">Elimină din Wishlist</button>
                            </form>
                        }
                        else
                        {
                            <form asp-controller="Wishlist" asp-action="Add" method="post">
                                <input type="hidden" name="carId" value="@Model.Id" />
                                <button type="submit" class="btn btn-outline-secondary">Adaugă la Wishlist</button>
                            </form>
                        }

                        if (!Model.IsSold)
                        {
                            <a asp-controller="TestDrives" asp-action="Book" asp-route-carId="@Model.Id" class="btn btn-primary">Programează Test Drive</a>
                        }
                    }

                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Editează</a>
                        if (!Model.IsSold)
                        {
                            <a asp-action="Sell" asp-route-id="@Model.Id" class="btn btn-primary">Vinde</a>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>
