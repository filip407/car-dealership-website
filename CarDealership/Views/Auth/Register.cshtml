@{
    ViewData["Title"] = "Cont Nou";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h3 class="text-center mb-4">Creare Cont Client</h3>
                <form asp-action="Register" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <div class="form-group mb-3">
                        <label for="fullName" class="form-label">Nume Complet</label>
                        <input type="text" id="fullName" name="fullName" class="form-control" required />
                    </div>
                    <div class="form-group mb-3">
                        <label for="email" class="form-label">Email</label>
                        <input type="email" id="email" name="email" class="form-control" required />
                    </div>
                    <div class="form-group mb-3">
                        <label for="password" class="form-label">Parolă</label>
                        <input type="password" id="password" name="password" class="form-control" required />
                    </div>
                    <div class="form-group mb-4">
                        <label for="confirmPassword" class="form-label">Confirmare Parolă</label>
                        <input type="password" id="confirmPassword" name="confirmPassword" class="form-control" required />
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Creează Cont</button>
                </form>
                <div class="text-center mt-3">
                    <small class="text-muted">Ai deja cont? <a asp-controller="Auth" asp-action="Login">Autentifică-te</a></small>
                </div>
            </div>
        </div>
    </div>
</div>
