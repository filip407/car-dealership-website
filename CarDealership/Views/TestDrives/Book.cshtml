@{
    ViewData["Title"] = "Programează Test Drive";
    var car = ViewBag.Car as CarDealership.Models.Car;
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <h2 class="mb-4">Programează Test Drive</h2>
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <h5 class="card-title">@car?.Brand?.Name @car?.ModelName</h5>
                <p class="text-muted">An: @car?.Year | Preț: @car?.Price.ToString("C")</p>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Book" method="post">
                    <input type="hidden" name="carId" value="@car?.Id" />
                    <div class="form-group mb-3">
                        <label class="form-label">Data și ora dorită</label>
                        <input type="datetime-local" name="scheduledAt" class="form-control" required
                               min="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
                    </div>
                    <div class="form-group mb-4">
                        <label class="form-label">Observații (opțional)</label>
                        <textarea name="notes" class="form-control" rows="3" placeholder="Ex: prefer dimineața, am întrebări despre motor..."></textarea>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Trimite Cererea</button>
                        <a asp-controller="Cars" asp-action="Details" asp-route-id="@car?.Id" class="btn btn-outline-secondary">Înapoi</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
