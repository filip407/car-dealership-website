@{
    ViewData["Title"] = "Gestiune Dotări";
}

<div class="row mt-4" id="vue-app">
    <div class="col-md-6 offset-md-3">
        <div class="card shadow-sm border-primary">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h4 class="mb-0">Dotări Auto (SPA Vue.js)</h4>
                <span class="badge bg-light text-primary">{{ features.length }} dotări</span>
            </div>
            <div class="card-body">

                <div class="input-group mb-4">
                    <input type="text" v-model="newFeatureName" @@keyup.enter="addFeature" class="form-control" placeholder="Ex: Scaune încălzite, Navigație GPS..." />
                    <button @@click="addFeature" class="btn btn-success" :disabled="!newFeatureName">Adaugă Dotare</button>
                </div>

                <ul class="list-group">
                    <li v-for="feature in features" :key="feature.id" class="list-group-item d-flex justify-content-between align-items-center">
                        {{ feature.name }}
                        <button @@click="deleteFeature(feature.id)" class="btn btn-sm btn-outline-danger">Șterge</button>
                    </li>
                </ul>

                <div v-if="features.length === 0" class="text-center text-muted mt-3">
                    Nu există nicio dotare în baza de date. Adaugă una mai sus!
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>

    <script>const { createApp, ref, onMounted } = Vue;

        createApp({
            setup() {
                const features = ref([]);
                const newFeatureName = ref('');

                const loadFeatures = async () => {
                    const response = await fetch('/api/features');
                    if (response.ok) {
                        features.value = await response.json();
                    }
                };

                const addFeature = async () => {
                    if (!newFeatureName.value) return;

                    const response = await fetch('/api/features', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ name: newFeatureName.value })
                    });

                    if (response.ok) {
                        newFeatureName.value = '';
                        await loadFeatures();
                    }
                };

                const deleteFeature = async (id) => {
                    if (confirm("Sigur vrei să ștergi această dotare?")) {
                        const response = await fetch(`/api/features/${id}`, {
                            method: 'DELETE'
                        });

                        if (response.ok) {
                            await loadFeatures();
                        }
                    }
                };

                onMounted(() => {
                    loadFeatures();
                });

                return {
                    features,
                    newFeatureName,
                    addFeature,
                    deleteFeature
                };
            }
        }).mount('#vue-app');</script>
}