@{
    ViewData["Title"] = "Gestiune Dotări";
}

<div class="row mt-4" id="vue-app">
    <div class="col-md-6 offset-md-3">
        <div class="card shadow-sm border-primary">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h4 class="mb-0">Dotări Auto (SPA Vue.js)</h4>
                <span class="badge bg-light text-primary">{{ features.length }} dotări</span>
            </div>
            <div class="card-body">

                <div class="input-group mb-4">
                    <input type="text" v-model="newFeatureName" @@keyup.enter="addFeature" class="form-control" placeholder="Ex: Scaune încălzite, Navigație GPS..." :disabled="isLoading" />
                    <button @@click="addFeature" class="btn btn-success" :disabled="!newFeatureName || isLoading">Adaugă Dotare</button>
                </div>

                <div v-if="errorMessage" class="alert alert-danger py-2 mb-3">{{ errorMessage }}</div>

                <div v-if="isLoading" class="text-center text-muted py-3">Se încarcă...</div>

                <ul v-else class="list-group">
                    <li v-for="feature in features" :key="feature.id" class="list-group-item d-flex justify-content-between align-items-center">
                        {{ feature.name }}
                        <button @@click="deleteFeature(feature.id)" class="btn btn-sm btn-outline-danger" :disabled="isLoading">Șterge</button>
                    </li>
                </ul>

                <div v-if="!isLoading && features.length === 0" class="text-center text-muted mt-3">
                    Nu există nicio dotare în baza de date. Adaugă una mai sus!
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>

    <script>const { createApp, ref, onMounted } = Vue;

        createApp({
            setup() {
                const features = ref([]);
                const newFeatureName = ref('');
                const isLoading = ref(false);
                const errorMessage = ref('');

                const loadFeatures = async () => {
                    isLoading.value = true;
                    errorMessage.value = '';
                    try {
                        const response = await fetch('/api/features');
                        if (!response.ok) throw new Error('Eroare la încărcarea dotărilor.');
                        features.value = await response.json();
                    } catch (err) {
                        errorMessage.value = err.message;
                    } finally {
                        isLoading.value = false;
                    }
                };

                const addFeature = async () => {
                    if (!newFeatureName.value) return;
                    isLoading.value = true;
                    errorMessage.value = '';
                    try {
                        const response = await fetch('/api/features', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ name: newFeatureName.value })
                        });
                        if (!response.ok) throw new Error('Eroare la adăugarea dotării.');
                        newFeatureName.value = '';
                        await loadFeatures();
                    } catch (err) {
                        errorMessage.value = err.message;
                        isLoading.value = false;
                    }
                };

                const deleteFeature = async (id) => {
                    if (confirm("Sigur vrei să ștergi această dotare?")) {
                        isLoading.value = true;
                        errorMessage.value = '';
                        try {
                            const response = await fetch(`/api/features/${id}`, { method: 'DELETE' });
                            if (!response.ok) throw new Error('Eroare la ștergerea dotării.');
                            await loadFeatures();
                        } catch (err) {
                            errorMessage.value = err.message;
                            isLoading.value = false;
                        }
                    }
                };

                onMounted(() => {
                    loadFeatures();
                });

                return {
                    features,
                    newFeatureName,
                    isLoading,
                    errorMessage,
                    addFeature,
                    deleteFeature
                };
            }
        }).mount('#vue-app');</script>
}